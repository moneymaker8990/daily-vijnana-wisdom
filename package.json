{
  "name": "mindvanta",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js",
    "build": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc && node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "release:check": "node ./scripts/release-check.mjs",
    "release:check:strict": "node ./scripts/release-check.mjs --strict",
    "release:prep": "node ./scripts/release-prep.mjs",
    "ship:preflight": "npm run typecheck && npm test -- --run && npm run build && npm run release:check:strict",
    "sync-versions": "node ./scripts/sync-versions.mjs",
    "verify:urls": "node ./scripts/verify-public-urls.mjs",
    "assets:feature-graphic": "node ./scripts/generate-feature-graphic.cjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test tests/e2e/vercel-prod-smoke.spec.ts -c playwright.vercel.config.ts",
    "test:ai-health": "node ./scripts/test-hyper-processor-health.mjs",
    "supabase:link": "npx supabase link --project-ref coihujjfdhpqfwmibfbi",
    "supabase:db:push": "npx supabase db push",
    "supabase:functions:deploy:all": "npx supabase functions deploy hyper-processor --no-verify-jwt --project-ref coihujjfdhpqfwmibfbi && npx supabase functions deploy check-entitlement --no-verify-jwt --project-ref coihujjfdhpqfwmibfbi && npx supabase functions deploy stripe-checkout --no-verify-jwt --project-ref coihujjfdhpqfwmibfbi && npx supabase functions deploy stripe-reconcile --no-verify-jwt --project-ref coihujjfdhpqfwmibfbi && npx supabase functions deploy stripe-webhook --no-verify-jwt --project-ref coihujjfdhpqfwmibfbi",
    "ingest:metadata:dry": "tsx scripts/ingestion/runIngestMetadata.ts --dry-run",
    "ingest:metadata:sql": "tsx scripts/ingestion/runIngestMetadata.ts --emit-sql scripts/ingestion/_generated_candidates.sql",
    "ingest:metadata:push": "npm run ingest:metadata:sql && npx supabase db query --linked -f scripts/ingestion/_generated_candidates.sql",
    "ingest:metadata": "tsx scripts/ingestion/runIngestMetadata.ts",
    "ingest:texts": "tsx scripts/ingestion/ingestTexts.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "dotenv": "^17.4.2",
    "jsdom": "^26.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@capacitor/ios": "^7.4.4",
    "@capacitor/local-notifications": "^7.0.3",
    "@capacitor/push-notifications": "^7.0.3",
    "@revenuecat/purchases-capacitor": "^11.3.2",
    "@sentry/react": "^10.40.0",
    "@supabase/functions-js": "2.87.1",
    "@supabase/supabase-js": "^2.87.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
